<?xml version="1.0"?>
<!--
  robot_description_pkg/urdf/wheels.xacro
  Drive wheels + passive casters with fallback visuals
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- PARAMETERS -->
  <xacro:property name="wheel_radius"         value="0.080"/>
  <xacro:property name="wheel_width"          value="0.055"/>
  <xacro:property name="wheel_mass"           value="1.200"/>
  <xacro:property name="wheel_x_offset"       value="0.140"/>
  <xacro:property name="wheel_y_offset"       value="0.230"/>
  <xacro:property name="wheel_z_offset"       value="0.000"/>

  <xacro:property name="caster_radius"        value="0.045"/>
  <xacro:property name="caster_mass"          value="0.300"/>
  <xacro:property name="caster_x_offset"      value="-0.175"/>
  <xacro:property name="caster_y_offset"      value="0.140"/>
  <xacro:property name="caster_z_offset"      value="${-(0.080 - caster_radius)}"/>

  <xacro:property name="wheel_effort_limit"   value="25.0"/>
  <xacro:property name="wheel_vel_limit"      value="10.0"/>
  <xacro:property name="wheel_damping"        value="0.05"/>
  <xacro:property name="wheel_friction_gz"    value="1.20"/>
  <xacro:property name="caster_friction_gz"   value="0.001"/>

  <xacro:property name="contact_kp"           value="1000000.0"/>
  <xacro:property name="contact_kd"           value="1.0"/>
  <xacro:property name="contact_min_depth"    value="0.001"/>
  <xacro:property name="contact_max_vel"      value="1.000"/>

  <xacro:property name="M_PI"                 value="3.14159265358979"/>

  <!-- DRIVE WHEEL MACRO -->
  <xacro:macro name="drive_wheel" params="prefix y_sign">

    <link name="${prefix}_wheel_link">
      <!-- Primary visual: try mesh -->
      <visual>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <geometry>
          <mesh filename="package://robot_description_pkg/meshes/wheel.stl" scale="1 1 1"/>
        </geometry>
        <material name="almost_black"/>
      </visual>

      <!-- Fallback visual: cylinder (RViz shows this if mesh missing) -->
      <visual>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="almost_black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <mass value="${wheel_mass}"/>
        <xacro:hollow_cylinder_inertia
          m="${wheel_mass}"
          r_o="${wheel_radius}"
          r_i="${0.55 * wheel_radius}"
          h="${wheel_width}"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="${wheel_x_offset} ${y_sign * wheel_y_offset} ${wheel_z_offset}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="${wheel_damping}" friction="0.0"/>
      <limit effort="${wheel_effort_limit}" velocity="${wheel_vel_limit}"/>
    </joint>

    <gazebo reference="${prefix}_wheel_link">
      <mu1 value="${wheel_friction_gz}"/>
      <mu2 value="${wheel_friction_gz}"/>
      <kp  value="${contact_kp}"/>
      <kd  value="${contact_kd}"/>
      <fdir1>1 0 0</fdir1>
      <minDepth>${contact_min_depth}</minDepth>
      <maxVel>${contact_max_vel}</maxVel>
      <material>Gazebo/Black</material>
    </gazebo>

  </xacro:macro>

  <!-- PASSIVE CASTER MACRO -->
  <xacro:macro name="passive_caster" params="prefix y_sign">

    <link name="${prefix}_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="mid_grey"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${caster_mass}"/>
        <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
      </inertial>
    </link>

    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_caster_link"/>
      <origin xyz="${caster_x_offset} ${y_sign * caster_y_offset} ${caster_z_offset}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="${prefix}_caster_link">
      <mu1 value="${caster_friction_gz}"/>
      <mu2 value="${caster_friction_gz}"/>
      <kp  value="${contact_kp}"/>
      <kd  value="${contact_kd}"/>
      <material>Gazebo/Grey</material>
    </gazebo>

  </xacro:macro>

  <!-- INSTANTIATE -->
  <xacro:drive_wheel  prefix="left"  y_sign="1"/>
  <xacro:drive_wheel  prefix="right" y_sign="-1"/>
  <xacro:passive_caster prefix="left"  y_sign="1"/>
  <xacro:passive_caster prefix="right" y_sign="-1"/>

</robot>
